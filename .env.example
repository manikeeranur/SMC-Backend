
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# ── Server ───────────────────────────────────────────────────────────────────
# PORT → local only (set in .env). DO NOT add PORT to Render — Render sets it automatically.
FRONTEND_URL=https://smc.manikandan.site/

# ── Options Settings ─────────────────────────────────────────────────────────
MIN_PREMIUM=200
SL_PERCENT=30
RR_RATIO=2.5

# ── Render Auto-Sync (add these to Render env vars — one-time setup) ─────────
# After each Kite login, token is auto-saved to Render so restarts stay authenticated.
# RENDER_API_KEY  → Render Dashboard → Account Settings → API Keys
# RENDER_SERVICE_ID → from your service URL: dashboard.render.com/web/srv-XXXXXXXXXXXX
RENDER_API_KEY=your_render_api_key
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx

# ── Telegram Alerts (optional) ───────────────────────────────────────────────
# Get bot token from @BotFather, chat_id from @userinfobot or your channel ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
